OPLAB_API_BASE=https://api.oplab.com.br
OPLAB_EMAIL=seu-email
OPLAB_PASSWORD=sua-senha
# Alternativa ao login por email/senha:
# OPLAB_ACCESS_TOKEN=seu-token

# Ajuste estes caminhos se sua conta/API expuser rotas diferentes.
# Use {symbol} como placeholder do ativo, por exemplo PETR4.
OPLAB_UNDERLYING_PATH=/v3/market/stocks/{symbol}
OPLAB_OPTIONS_PATH=/v3/market/options/{symbol}
